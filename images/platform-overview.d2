# Agentopia Platform Overview — clean left-to-right flow
# Layout: Operator → SA → Developer → PR → Reviewer → Merged

direction: right

# ── Top-level shapes (flat, no nested containers for cleaner layout) ──

operator: {
  label: "Operator\n(Web App)"
  shape: rectangle
  style: {
    fill: "#312e81"
    stroke: "#818cf8"
    border-radius: 10
    font-color: "#e0e7ff"
    font-size: 16
    bold: true
  }
}

sa: {
  label: "Solution\nArchitect"
  shape: rectangle
  style: {
    fill: "#1e1b4b"
    stroke: "#6366f1"
    border-radius: 10
    font-color: "#c7d2fe"
    font-size: 16
    bold: true
  }
}

dev: {
  label: "Developer\nAgent"
  shape: rectangle
  style: {
    fill: "#1e1b4b"
    stroke: "#6366f1"
    border-radius: 10
    font-color: "#c7d2fe"
    font-size: 16
    bold: true
  }
}

pr: {
  label: "Pull\nRequest"
  shape: rectangle
  style: {
    fill: "#14532d"
    stroke: "#4ade80"
    border-radius: 10
    font-color: "#bbf7d0"
    font-size: 16
    bold: true
  }
}

reviewer: {
  label: "Code\nReviewer"
  shape: rectangle
  style: {
    fill: "#1e1b4b"
    stroke: "#6366f1"
    border-radius: 10
    font-color: "#c7d2fe"
    font-size: 16
    bold: true
  }
}

merged: {
  label: "Merged\nCode"
  shape: rectangle
  style: {
    fill: "#052e16"
    stroke: "#22c55e"
    border-radius: 10
    font-color: "#dcfce7"
    font-size: 16
    bold: true
  }
}

governance: {
  label: "Governance Layer"
  shape: rectangle
  style: {
    fill: "#451a03"
    stroke: "#f59e0b"
    border-radius: 10
    font-color: "#fde68a"
    font-size: 14
    stroke-dash: 5
  }
}

# ── Main flow (left to right) ────────────────────────

operator -> sa: "defines\nobjective" {
  style: {
    stroke: "#818cf8"
    font-color: "#a5b4fc"
    font-size: 13
    stroke-width: 2
  }
}

sa -> dev: "assigns\nwork" {
  style: {
    stroke: "#818cf8"
    font-color: "#a5b4fc"
    font-size: 13
    stroke-width: 2
  }
}

dev -> pr: "creates" {
  style: {
    stroke: "#4ade80"
    font-color: "#86efac"
    font-size: 13
    stroke-width: 2
  }
}

pr -> reviewer: "dispatches" {
  style: {
    stroke: "#818cf8"
    font-color: "#a5b4fc"
    font-size: 13
    stroke-width: 2
  }
}

reviewer -> merged: "approves" {
  style: {
    stroke: "#4ade80"
    font-color: "#86efac"
    font-size: 13
    stroke-width: 2
  }
}

# ── Governance (below, simple) ───────────────────────

governance -> sa: "" {
  style: {
    stroke: "#f59e0b"
    stroke-dash: 4
    stroke-width: 1
  }
}

governance -> dev: "" {
  style: {
    stroke: "#f59e0b"
    stroke-dash: 4
    stroke-width: 1
  }
}

governance -> reviewer: "" {
  style: {
    stroke: "#f59e0b"
    stroke-dash: 4
    stroke-width: 1
  }
}
