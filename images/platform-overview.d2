# Agentopia Platform Overview — vertical flow, large text
direction: down

operator: Operator (Web App) {
  style: {
    fill: "#312e81"
    stroke: "#818cf8"
    border-radius: 12
    font-color: "#e0e7ff"
    font-size: 22
    bold: true
    shadow: true
  }
}

sa: Solution Architect {
  style: {
    fill: "#1e1b4b"
    stroke: "#6366f1"
    border-radius: 12
    font-color: "#c7d2fe"
    font-size: 22
    bold: true
    shadow: true
  }
}

dev: Developer Agent {
  style: {
    fill: "#1e1b4b"
    stroke: "#6366f1"
    border-radius: 12
    font-color: "#c7d2fe"
    font-size: 22
    bold: true
    shadow: true
  }
}

pr: Pull Request {
  style: {
    fill: "#14532d"
    stroke: "#4ade80"
    border-radius: 12
    font-color: "#bbf7d0"
    font-size: 22
    bold: true
    shadow: true
  }
}

reviewer: Code Reviewer {
  style: {
    fill: "#1e1b4b"
    stroke: "#6366f1"
    border-radius: 12
    font-color: "#c7d2fe"
    font-size: 22
    bold: true
    shadow: true
  }
}

merged: Merged Code {
  style: {
    fill: "#052e16"
    stroke: "#22c55e"
    border-radius: 12
    font-color: "#dcfce7"
    font-size: 22
    bold: true
    shadow: true
  }
}

governance: Governance Layer {
  style: {
    fill: "#451a03"
    stroke: "#f59e0b"
    border-radius: 12
    font-color: "#fde68a"
    font-size: 18
    stroke-dash: 5
  }
}

# ── Main flow (top to bottom) ────────────────────────

operator -> sa: Defines objective {
  style: {
    stroke: "#818cf8"
    font-color: "#a5b4fc"
    font-size: 16
    stroke-width: 2
    bold: true
  }
}

sa -> dev: Assigns work {
  style: {
    stroke: "#818cf8"
    font-color: "#a5b4fc"
    font-size: 16
    stroke-width: 2
    bold: true
  }
}

dev -> pr: Creates {
  style: {
    stroke: "#4ade80"
    font-color: "#86efac"
    font-size: 16
    stroke-width: 2
    bold: true
  }
}

pr -> reviewer: Dispatches {
  style: {
    stroke: "#818cf8"
    font-color: "#a5b4fc"
    font-size: 16
    stroke-width: 2
    bold: true
  }
}

reviewer -> merged: Approves {
  style: {
    stroke: "#4ade80"
    font-color: "#86efac"
    font-size: 16
    stroke-width: 2
    bold: true
  }
}

# ── Governance (side connections) ─────────────────────

governance -> sa {
  style: {
    stroke: "#f59e0b"
    stroke-dash: 4
    stroke-width: 1
  }
}

governance -> dev {
  style: {
    stroke: "#f59e0b"
    stroke-dash: 4
    stroke-width: 1
  }
}

governance -> reviewer {
  style: {
    stroke: "#f59e0b"
    stroke-dash: 4
    stroke-width: 1
  }
}
